---
import recipes from '../data/recipes.json';
import inventory from '../data/inventory.json';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Graceful Aging — DIY Skin Care</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@200;300;400&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/x-icon" href="/skincare/images/skin_favicon.ico">
  <style>
    /* GT America — assumes you have the font files or a licensed CDN */
    @font-face {
      font-family: 'GT America';
      src: local('GT America'), local('GTAmerica');
      font-weight: 300 700;
      font-style: normal;
    }
  </style>
</head>

<body>

  <!-- HERO / WELCOME -->
  <section class="hero" id="top">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="hero-eyebrow">a personal collection</p>
      <h1>skin</h1>
      <p class="hero-sub">skin care recipes &middot; ingredients &middot; routines</p>
      <nav class="jumplinks">
        <a href="#ingredients">Base Ingredients</a>
        <a href="#essential-oils">Essential Oils</a>
        <a href="#equipment">Equipment & Tools</a>
        <span class="divider">—</span>
        {recipes.map(r => (
          <a href={`#${r.id}`}>{r.title}</a>
        ))}
      </nav>
    </div>
  </section>

  <!-- BASE INGREDIENTS -->
  <section class="inventory-section" id="ingredients">
    <div class="inventory-inner">
      <h2>Base Ingredients</h2>
      <ul>
        {inventory.baseIngredients.map(item => <li>{item}</li>)}
      </ul>
      <a href="#top" class="back-link">↑ back to top</a>
    </div>
  </section>

  <!-- ESSENTIAL OILS -->
  <section class="inventory-section alt" id="essential-oils">
    <div class="inventory-inner">
      <h2>Essential Oils</h2>
      <ul>
        {inventory.essentialOils.map(item => <li>{item}</li>)}
      </ul>
      <a href="#top" class="back-link">↑ back to top</a>
    </div>
  </section>

  <!-- EQUIPMENT & TOOLS -->
  <section class="inventory-section" id="equipment">
    <div class="inventory-inner">
      <h2>Equipment & Tools</h2>
      <ul>
        {inventory.equipment.map(item => <li>{item}</li>)}
      </ul>
      <a href="#top" class="back-link">↑ back to top</a>
    </div>
  </section>

  <!-- RECIPES -->
  {recipes.map((recipe, index) => (
    <section
      class={`recipe-section text-${recipe.textSide}${recipe.wide ? ' recipe-wide' : ''}`}
      id={recipe.id}
      style={`background-image: url('${recipe.image}')`}
    >
      <div class="recipe-overlay"></div>
      <div class="recipe-content">
        <p class="recipe-eyebrow">recipe</p>
        <h2>{recipe.title}</h2>
        <p class="recipe-subtitle">{recipe.subtitle}</p>

        {recipe.ratio && (
          <p class="recipe-ratio">{recipe.ratio}</p>
        )}

        {recipe.ingredients.length > 0 && (
          <div class="recipe-block">
            <h3>Ingredients</h3>
            <ul>
              {recipe.ingredients.map(ing => <li>{ing}</li>)}
            </ul>
          </div>
        )}

        {recipe.steps.length > 0 && (
          <div class="recipe-block">
            <h3>Method</h3>
            <ol>
              {recipe.steps.map(step => <li>{step}</li>)}
            </ol>
          </div>
        )}

        <nav class="recipe-nav">
          {index > 0
            ? <a href={`#${recipes[index - 1].id}`} class="recipe-nav-link">← {recipes[index - 1].title}</a>
            : <a href="#top" class="recipe-nav-link">← Back to Top</a>
          }
          {index < recipes.length - 1
            ? <a href={`#${recipes[index + 1].id}`} class="recipe-nav-link">{recipes[index + 1].title} →</a>
            : <a href="#top" class="recipe-nav-link">↑ Back to Top</a>
          }
        </nav>
      </div>
    </section>
  ))}

</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --cream: rgba(255, 252, 245, 0.92);
    --cream-dim: rgba(255, 252, 245, 0.75);
    --cream-faint: rgba(255, 252, 245, 0.55);
    --dark: #1a1510;
    --accent: rgba(210, 185, 150, 0.6);
    --font-display: 'GT America', 'Cormorant Garamond', Georgia, sans-serif;
    --font-body: 'Jost', sans-serif;
  }

  html { scroll-behavior: smooth; font-size: 20px; }

  body {
    background: var(--dark);
    color: var(--cream);
    font-family: var(--font-body);
    font-weight: 300;
  }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    background: #2a1f14;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 60%, rgba(180,140,90,0.15) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 20%, rgba(120,90,60,0.12) 0%, transparent 50%);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(26,21,16,0.3) 0%, rgba(26,21,16,0.1) 50%, rgba(26,21,16,0.5) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 3rem 2rem;
    max-width: 900px;
  }

  .hero-eyebrow {
    font-family: var(--font-body);
    font-weight: 200;
    font-size: 1rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--cream-dim);
    margin-bottom: 1.5rem;
  }

  .hero h1 {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(5rem, 10vw, 9rem);
    line-height: 1;
    letter-spacing: 0.02em;
    color: var(--cream);
    margin-bottom: 1rem;
  }

  .hero-sub {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.5rem, 2.5vw, 2.2rem);
    color: var(--cream-dim);
    margin-bottom: 3.5rem;
    letter-spacing: 0.05em;
  }

  .jumplinks {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 2rem;
    justify-content: center;
    align-items: center;
    border-top: 1px solid var(--accent);
    padding-top: 2rem;
  }

  .jumplinks a {
    color: var(--cream-dim);
    text-decoration: none;
    font-size: 1rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 300;
    transition: color 0.2s;
  }

  .jumplinks a:hover { color: var(--cream); }

  .jumplinks .divider {
    color: var(--accent);
    font-size: 1rem;
    width: 100%;
    text-align: center;
    margin: 0.25rem 0;
  }

  /* ── INVENTORY SECTIONS ── */
  .inventory-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #1e1810;
    padding: 5rem 2rem;
  }

  .inventory-section.alt {
    background: #221c12;
  }

  .inventory-inner {
    max-width: 700px;
    width: 100%;
  }

  .inventory-section h2 {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(2.5rem, 4vw, 4rem);
    color: var(--cream);
    margin-bottom: 2.5rem;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 1rem;
  }

  .inventory-section ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .inventory-section li {
    font-size: 1.2rem;
    color: var(--cream-dim);
    letter-spacing: 0.04em;
    padding-left: 1.5rem;
    position: relative;
  }

  .inventory-section li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 1.4rem;
    line-height: 1.2;
  }

   /* ── RECIPE SECTIONS ── */
  .recipe-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    padding: 3rem 4rem;
  }

  .recipe-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right,
      rgba(20,15,10,0.88) 0%,
      rgba(20,15,10,0.75) 50%,
      rgba(20,15,10,0.15) 100%
    );
  }

  .recipe-section.text-right .recipe-overlay {
    background: linear-gradient(to left,
      rgba(20,15,10,0.88) 0%,
      rgba(20,15,10,0.75) 50%,
      rgba(20,15,10,0.15) 100%
    );
  }

  .recipe-content {
    position: relative;
    z-index: 1;
    max-width: 900px;
    width: 60%;
  }

  .recipe-section.text-left .recipe-content { margin-left: 1rem; margin-right: auto; }
  .recipe-section.text-right .recipe-content { margin-left: auto; margin-right: 1rem; }

  .recipe-wide .recipe-content {
    max-width: 1100px;
    width: 78%;
  }

  .recipe-wide .recipe-overlay {
    background: linear-gradient(to right,
      rgba(20,15,10,0.92) 0%,
      rgba(20,15,10,0.82) 60%,
      rgba(20,15,10,0.25) 100%
    ) !important;
  }

  .recipe-wide.text-right .recipe-overlay {
    background: linear-gradient(to left,
      rgba(20,15,10,0.92) 0%,
      rgba(20,15,10,0.82) 60%,
      rgba(20,15,10,0.25) 100%
    ) !important;
  }

  .recipe-eyebrow {
    font-size: 1rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--cream-faint);
    margin-bottom: 0.75rem;
  }

  .recipe-content h2 {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(3rem, 5vw, 3rem);
    line-height: 1.1;
    color: var(--cream);
    margin-bottom: 0.4rem;
  }

  .recipe-subtitle {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.4rem;
    color: var(--cream-dim);
    margin-bottom: 1.5rem;
  }

  .recipe-ratio {
    font-size: 1.1rem;
    letter-spacing: 0.06em;
    color: var(--cream-faint);
    border-left: 2px solid var(--accent);
    padding-left: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .recipe-block { margin-bottom: 1.5rem; }

  .recipe-block h3 {
    font-family: var(--font-body);
    font-weight: 200;
    font-size: 0.9rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--cream-faint);
    margin-bottom: 0.75rem;
  }

  .recipe-block ul,
  .recipe-block ol {
    padding-left: 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .recipe-block li {
    font-size: 1.15rem;
    color: var(--cream-dim);
    line-height: 1.6;
    letter-spacing: 0.02em;
  }

  .back-link {
    display: inline-block;
    margin-top: 2.5rem;
    font-size: 0.9rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--cream-faint);
    text-decoration: none;
    transition: color 0.2s;
  }

  .back-link:hover { color: var(--cream); }

  .recipe-nav {
    display: flex;
    gap: 2rem;
    margin-top: 2.5rem;
    flex-wrap: wrap;
  }

  .recipe-nav-link {
    font-size: 0.9rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--cream-faint);
    text-decoration: none;
    transition: color 0.2s;
  }

  .recipe-nav-link:hover { color: var(--cream); }

  /* ── RESPONSIVE ── */
  @media (max-width: 640px) {
    .recipe-section {
      padding: 4rem 2rem;
    }
    .recipe-content {
      width: 100%;
    }
    .recipe-section.text-left .recipe-content,
    .recipe-section.text-right .recipe-content {
      margin: 0 auto;
    }
    .recipe-overlay,
    .recipe-section.text-right .recipe-overlay {
      background: rgba(20,15,10,0.82);
    }
  }
</style>
